# Upstox API Credentials
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here
UPSTOX_TOTP_SECRET=your_totp_secret_here

# Database URLs (defaults set in docker-compose)
DATABASE_URL=postgresql+asyncpg://nifty50:nifty50pass@timescale:5432/nifty50_timeseries
LOGS_DATABASE_URL=postgresql+asyncpg://nifty50logs:nifty50logspass@postgres:5432/nifty50_logs

# App Settings
LOG_LEVEL=INFO
TZ=Asia/Kolkata
REFRESH_INTERVAL_SECONDS=300
WEBSOCKET_ENABLED=true
